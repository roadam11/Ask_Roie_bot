{
  "$schema": "https://railway.app/railway.schema.json",
  "service": "followup-worker",
  "description": "BullMQ worker - processes follow-up message queue",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "npm run worker:followup",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
