{
  "$schema": "https://railway.app/railway.schema.json",
  "service": "scheduler",
  "description": "Cron scheduler - queues follow-ups and polls Calendly",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "npm run worker:scheduler",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
