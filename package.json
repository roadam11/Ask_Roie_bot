{
  "name": "ask-roie-bot",
  "version": "1.0.0",
  "description": "WhatsApp AI Sales Agent for Ask ROIE tutoring service",
  "main": "dist/server.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "db:migrate": "tsx scripts/setup-db.ts",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "worker:followup": "tsx src/workers/followup.worker.ts",
    "worker:calendly": "tsx src/workers/calendly.worker.ts",
    "worker:scheduler": "tsx src/workers/scheduler.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "bullmq": "^5.1.0",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "bottleneck": "^2.19.5",
    "node-schedule": "^2.1.1",
    "zod": "^3.22.4",
    "helmet": "^7.1.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/node-schedule": "^2.1.5",
    "@types/cors": "^2.8.17",
    "typescript": "^5.3.2",
    "tsx": "^4.6.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "ts-jest": "^29.1.1",
    "eslint": "^8.54.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "prettier": "^3.1.0"
  }
}
