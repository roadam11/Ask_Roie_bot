# Railway Environment Variables for Local Testing
# Copy this file to .env.railway and fill in the values from Railway dashboard
#
# Get values from: Railway Dashboard → Project → Variables
# Or run: railway variables

# Database (Railway Postgres)
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway

# Redis (Railway Redis)
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxx

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_ACCESS_TOKEN=EAAxx...
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-xxx

# Calendly (optional)
CALENDLY_API_KEY=xxx
CALENDLY_WEBHOOK_SECRET=xxx

# App Config
NODE_ENV=production
PORT=3000
