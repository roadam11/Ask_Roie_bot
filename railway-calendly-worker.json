{
  "$schema": "https://railway.app/railway.schema.json",
  "service": "calendly-worker",
  "description": "BullMQ worker - processes Calendly booking detection",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "npm run worker:calendly",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
