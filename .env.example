# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/askroie
REDIS_URL=redis://localhost:6379

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_secret_verify_token

# Claude API
ANTHROPIC_API_KEY=sk-ant-api-key-here

# Calendly
CALENDLY_ACCESS_TOKEN=your_calendly_token
CALENDLY_ORGANIZATION_URI=https://api.calendly.com/organizations/your-org-id
CALENDLY_EVENT_TYPE_URI=https://api.calendly.com/event_types/your-event-type-id

# Admin
ADMIN_PASSWORD=your_secure_password
ADMIN_USERNAME=roie

# Logging
LOG_LEVEL=info
